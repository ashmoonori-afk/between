{
  "name": "vscode-between",
  "displayName": "Between",
  "description": "Local Between broker panel and review actions for VS Code.",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "publisher": "between-local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./src/extension.js",
  "activationEvents": [
    "onView:between.panel",
    "onCommand:between.openIde",
    "onCommand:between.refresh",
    "onCommand:between.openEvidence",
    "onCommand:between.requestSecondReview",
    "onCommand:between.askDeveloperToFix",
    "onCommand:between.approveExactBundle"
  ],
  "contributes": {
    "views": {
      "scm": [
        {
          "id": "between.panel",
          "name": "Between"
        }
      ]
    },
    "commands": [
      {
        "command": "between.openIde",
        "title": "Between: Open IDE"
      },
      {
        "command": "between.refresh",
        "title": "Between: Refresh"
      },
      {
        "command": "between.openEvidence",
        "title": "Between: Open Evidence"
      },
      {
        "command": "between.requestSecondReview",
        "title": "Between: Request Second Review"
      },
      {
        "command": "between.askDeveloperToFix",
        "title": "Between: Ask Developer To Fix"
      },
      {
        "command": "between.approveExactBundle",
        "title": "Between: Approve Exact Bundle"
      }
    ]
  },
  "scripts": {
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p jsconfig.json --noEmit",
    "test": "node ./test/run-vitest.mjs",
    "test:host": "vscode-test --label task-9-diagnostics && vscode-test --label task-9-stale --grep \"clears stale diagnostics\"",
    "check": "npm run typecheck && npm test && npm run test:host"
  },
  "devDependencies": {
    "@types/vscode": "1.90.0",
    "@vscode/test-cli": "0.0.12",
    "@vscode/test-electron": "3.0.0"
  },
  "dependencies": {
    "yaml": "^2.9.0"
  }
}
