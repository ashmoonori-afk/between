{
  "name": "between",
  "version": "0.1.0",
  "private": true,
  "description": "A local terminal broker for AI pair development — observe a developer (Claude) and reviewer (Codex) terminal and coordinate a diff-driven review loop.",
  "type": "module",
  "bin": {
    "between": "dist/cli.js"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "between": "tsx src/cli.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --no-file-parallelism --reporter=verbose",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage --no-file-parallelism --reporter=verbose",
    "lint": "prettier --check \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"test/**/*.{ts,tsx}\""
  },
  "license": "MIT",
  "dependencies": {
    "chokidar": "^5.0.0",
    "commander": "^15.0.0",
    "execa": "^9.6.1",
    "ink": "^7.1.0",
    "pino": "^10.3.1",
    "proper-lockfile": "^4.1.2",
    "react": "^19.2.7",
    "write-file-atomic": "^7.0.1",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@sinonjs/fake-timers": "^15.4.0",
    "@types/node": "^25.9.3",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.2.17",
    "@vitest/coverage-v8": "^4.1.9",
    "ink-testing-library": "^4.0.0",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "optionalDependencies": {
    "@lydell/node-pty": "^1.2.0-beta.12"
  }
}
